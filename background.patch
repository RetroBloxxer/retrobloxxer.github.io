From c6781bb668a88eada024533d2988a090fdc2b22c Mon Sep 17 00:00:00 2001
From: backups1der <anins1der@proton.me>
Date: Fri, 5 Jun 2026 16:37:54 +0300
Subject: [PATCH] Set background scroll thingy to all pages and change the
 background

---
 content/_index.md     |   1 -
 sass/background.scss  |  12 ++----------
 static/background.png | Bin 29348 -> 1133814 bytes
 zola.toml             |   2 +-
 4 files changed, 3 insertions(+), 12 deletions(-)

diff --git a/content/_index.md b/content/_index.md
index 27434be..0bdb6c1 100644
--- a/content/_index.md
+++ b/content/_index.md
@@ -1,7 +1,6 @@
 +++
 title = "RetroBloxxer"
 [extra]
-styles = ["background.css"]
 no_header = true
 +++
 
diff --git a/sass/background.scss b/sass/background.scss
index 14d692f..dadb173 100644
--- a/sass/background.scss
+++ b/sass/background.scss
@@ -1,14 +1,6 @@
 body {
   background-image: var(--bg-overlay), url("./background.png");
-  background-size: 200px;
-  background-repeat: repeat;
+  background-size: contain;
+  background-repeat: repeat-x;
   background-attachment: fixed;
-
-  animation: infinite scroll 1s linear;
-
-  @keyframes scroll { 
-    from {
-      background-position: 200px 200px
-    }
-  }
 }
\ No newline at end of file
